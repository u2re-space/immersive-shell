{
    "include": ["./src/**/*.ts", "./demo/**/*.ts", "./test/**/*.ts", "./*.js"],
    "exclude": ["./dist/**/*"],
    "compilerOptions": {
        "outDir": "./dist/",
        "paths": {
            "boot/ts/*": ["../../projects/subsystem/src/boot/*"],
            "views/types": ["../../views/shared/types.ts"],
            "views/registry": ["../../views/shared/registry.ts"],
            "shells/*": ["../../views/shared/views/*"],
            "core/*": ["../../views/shared/src/*"],
            "com/*": ["../../views/shared/src/*"],
            "shared/*": ["../../views/shared/src/*"],
            "@shared/*": ["../../views/shared/*"],
            "fonts/*": ["../../views/shared/assets/fonts/*"],
            "fest/*": ["../../views/shared/fest/*"],
            "fest/dom": ["../../projects/dom.ts/src/index.ts"],
            "fest/lure": ["../../projects/lur.e/src/index.ts"],
            "fest/object": ["../../projects/object.ts/src/index.ts"],
            "fest/core": ["../../projects/core.ts/src/index.ts"],
            "fest/icon": ["../../projects/icon.ts/src/index.ts"],
            "fest/fl-ui": ["../../projects/fl.ui/src/index.ts"],
            "fest/image": ["../../projects/image.ts/src/index.ts"],
            "fest/ui": ["../../projects/fl.ui/src/index.ts"],
            "fest/uniform": ["../../projects/uniform.ts/src/index.ts"],
            "fest/subsystem": ["../../projects/subsystem/src/index.ts"],
            "fest/polyfill/*": ["../../projects/shared/fest/polyfill/*"],
            "polyfill/*": ["../../projects/shared/fest/polyfill/*"],
            "veela-lib": ["../../projects/veela.css/src/scss/index.scss"],
            "veela-lib/*": ["../../projects/veela.css/src/scss/*"]
        },
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ESNext", "DOM", "WebWorker"],
        "esModuleInterop": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "allowArbitraryExtensions": true,
        "allowSyntheticDefaultImports": true,
        "noImplicitAny": false,
        "declaration": false,
        "noEmit": true,
        "experimentalDecorators": true
    }
}
